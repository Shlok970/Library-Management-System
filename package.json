{
  "name": "library-management-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=frontend && npm install --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:frontend:wait": "wait-on http://localhost:3000/api/health && npm run dev:frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend:wait\"",
    "build:frontend": "npm run build --workspace=frontend",
    "lint:frontend": "npm run lint --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wait-on": "^9.0.5"
  }
}
